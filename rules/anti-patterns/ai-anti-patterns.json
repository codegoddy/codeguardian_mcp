{
  "patterns": [
    {
      "id": "AP-001",
      "name": "Empty Catch Block",
      "category": "error-handling",
      "severity": "high",
      "description": "Empty catch block silently swallows errors",
      "pattern": "catch\\s*\\([^)]*\\)\\s*\\{\\s*\\}",
      "languages": ["javascript", "typescript", "java"],
      "fix": "Add proper error handling: log the error, rethrow, or handle gracefully",
      "example": "catch (error) { console.error('Error:', error); }",
      "aiGenerated": true
    },
    {
      "id": "AP-002",
      "name": "Generic Catch-All Handler",
      "category": "error-handling",
      "severity": "medium",
      "description": "Catch-all error handler without specific error handling",
      "pattern": "catch\\s*\\([^)]*\\)\\s*\\{[^}]*console\\.(log|error)\\([^)]*\\)[^}]*\\}",
      "languages": ["javascript", "typescript"],
      "fix": "Handle specific error types differently or add recovery logic",
      "example": "catch (error) { if (error instanceof NetworkError) { retry(); } }",
      "aiGenerated": true
    },
    {
      "id": "AP-003",
      "name": "Magic Number",
      "category": "maintainability",
      "severity": "low",
      "description": "Hardcoded numeric value without explanation",
      "pattern": "(?<!(const|let|var|\\w+=)|test\\.)\\b(100|200|404|500|1000|3600|86400)\\b",
      "languages": ["javascript", "typescript", "python"],
      "fix": "Extract to named constant: const MAX_RETRIES = 3;",
      "example": "const TIMEOUT_MS = 5000;",
      "aiGenerated": true
    },
    {
      "id": "AP-005",
      "name": "Unused Variable",
      "category": "dead-code",
      "severity": "low",
      "description": "Variable declared but never used",
      "pattern": "(?:const|let|var)\\s+(\\w+)\\s*=(?!.*\\1)",
      "languages": ["javascript", "typescript"],
      "fix": "Remove unused variable or use it",
      "example": "// Remove: const unused = 123;",
      "aiGenerated": true
    },
    {
      "id": "AP-006",
      "name": "Console.log in Production",
      "category": "debugging",
      "severity": "medium",
      "description": "Debug console.log statements left in code",
      "pattern": "console\\.log\\s*\\(",
      "languages": ["javascript", "typescript"],
      "fix": "Remove console.log or use proper logging library",
      "example": "logger.debug('Debug info');",
      "aiGenerated": true
    },
    {
      "id": "AP-007",
      "name": "TODO Comment",
      "category": "incomplete",
      "severity": "low",
      "description": "TODO comment indicating incomplete code",
      "pattern": "//\\s*TODO|#\\s*TODO",
      "languages": ["javascript", "typescript", "python"],
      "fix": "Complete the TODO or create a ticket",
      "example": "// Create ticket: JIRA-123",
      "aiGenerated": true
    },
    {
      "id": "AP-008",
      "name": "Overly Long Function",
      "category": "complexity",
      "severity": "medium",
      "description": "Function with too many lines (>50)",
      "pattern": "function\\s+\\w+\\s*\\([^)]*\\)\\s*\\{[\\s\\S]{500,}?\\}",
      "languages": ["javascript", "typescript"],
      "fix": "Break into smaller, focused functions",
      "example": "Split into: validateInput(), processData(), saveResult()",
      "aiGenerated": true
    },
    {
      "id": "AP-009",
      "name": "Deeply Nested Conditions",
      "category": "complexity",
      "severity": "high",
      "description": "More than 3 levels of nested if statements",
      "pattern": "if\\s*\\([^)]+\\)\\s*\\{[^}]*if\\s*\\([^)]+\\)\\s*\\{[^}]*if\\s*\\([^)]+\\)\\s*\\{[^}]*if",
      "languages": ["javascript", "typescript", "python"],
      "fix": "Use early returns or extract to separate functions",
      "example": "if (!valid) return; // Early return",
      "aiGenerated": true
    },
    {
      "id": "AP-010",
      "name": "Duplicate Code Block",
      "category": "duplication",
      "severity": "medium",
      "description": "Similar code blocks that could be extracted",
      "pattern": "(?:const|let)\\s+\\w+\\s*=\\s*\\{[^}]+\\};[\\s\\S]{0,100}(?:const|let)\\s+\\w+\\s*=\\s*\\{[^}]+\\};",
      "languages": ["javascript", "typescript"],
      "fix": "Extract common logic to a function or use a factory",
      "example": "function createConfig(options) { return {...defaults, ...options}; }",
      "aiGenerated": true
    },
    {
      "id": "AP-011",
      "name": "Missing Input Validation",
      "category": "safety",
      "severity": "high",
      "description": "Function parameter used without validation",
      "pattern": "function\\s+\\w+\\s*\\(\\s*(\\w+)\\s*\\)\\s*\\{(?!.*(?:if|throw|assert|validate))",
      "languages": ["javascript", "typescript"],
      "fix": "Add input validation at function start",
      "example": "if (!input) throw new Error('Input required');",
      "aiGenerated": true
    },
    {
      "id": "AP-012",
      "name": "Callback Hell",
      "category": "complexity",
      "severity": "high",
      "description": "Deeply nested callbacks (pyramid of doom)",
      "pattern": "\\([^)]*\\)\\s*=>\\s*\\{[^}]*\\([^)]*\\)\\s*=>\\s*\\{[^}]*\\([^)]*\\)\\s*=>",
      "languages": ["javascript", "typescript"],
      "fix": "Use async/await or Promise.all()",
      "example": "const result = await fetchData();",
      "aiGenerated": true
    },
    {
      "id": "AP-013",
      "name": "Unused Import",
      "category": "dead-code",
      "severity": "low",
      "description": "Imported module never used",
      "pattern": "import\\s+\\{?\\s*(\\w+)\\s*\\}?\\s+from(?!.*\\1)",
      "languages": ["javascript", "typescript"],
      "fix": "Remove unused import",
      "example": "// Remove: import { unused } from 'module';",
      "aiGenerated": true
    },
    {
      "id": "AP-014",
      "name": "Inconsistent Naming",
      "category": "style",
      "severity": "low",
      "description": "Mixed naming conventions (camelCase, snake_case)",
      "pattern": "(?:const|let|var)\\s+([a-z]+_[a-z]+)\\s*=",
      "languages": ["javascript", "typescript"],
      "fix": "Use consistent camelCase naming",
      "example": "const userName instead of user_name",
      "aiGenerated": true
    },
    {
      "id": "AP-015",
      "name": "Missing Return Type",
      "category": "type-safety",
      "severity": "medium",
      "description": "TypeScript function without return type annotation",
      "pattern": "function\\s+\\w+\\s*\\([^)]*\\)\\s*\\{",
      "languages": ["typescript"],
      "fix": "Add explicit return type annotation",
      "example": "function getName(): string { return name; }",
      "aiGenerated": true
    },
    {
      "id": "AP-016",
      "name": "Any Type Usage",
      "category": "type-safety",
      "severity": "high",
      "description": "Using 'any' type defeats TypeScript's purpose",
      "pattern": ":\\s*any\\b",
      "languages": ["typescript"],
      "fix": "Use specific types or unknown",
      "example": "const data: UserData instead of data: any",
      "aiGenerated": true
    },
    {
      "id": "AP-017",
      "name": "Synchronous File Operations",
      "category": "performance",
      "severity": "medium",
      "description": "Using synchronous fs methods blocks event loop",
      "pattern": "fs\\.(readFileSync|writeFileSync|existsSync)",
      "languages": ["javascript", "typescript"],
      "fix": "Use async versions: fs.promises.readFile()",
      "example": "const data = await fs.promises.readFile(path);",
      "aiGenerated": true
    },
    {
      "id": "AP-018",
      "name": "Missing Async/Await",
      "category": "async",
      "severity": "medium",
      "description": "Promise not awaited or handled",
      "pattern": "\\w+\\([^)]*\\)\\.then\\(",
      "languages": ["javascript", "typescript"],
      "fix": "Use async/await for better readability",
      "example": "const result = await fetchData();",
      "aiGenerated": true
    },
    {
      "id": "AP-019",
      "name": "Bare Except (Python)",
      "category": "error-handling",
      "severity": "high",
      "description": "Catching all exceptions without specificity",
      "pattern": "except\\s*:",
      "languages": ["python"],
      "fix": "Catch specific exceptions: except ValueError:",
      "example": "except (ValueError, TypeError) as e:",
      "aiGenerated": true
    },
    {
      "id": "AP-020",
      "name": "Mutable Default Argument (Python)",
      "category": "bugs",
      "severity": "high",
      "description": "Using mutable default argument (list, dict)",
      "pattern": "def\\s+\\w+\\s*\\([^)]*=\\s*(?:\\[\\]|\\{\\})",
      "languages": ["python"],
      "fix": "Use None as default and create inside function",
      "example": "def func(items=None): items = items or []",
      "aiGenerated": true
    },
    {
      "id": "AP-021",
      "name": "Global Variable Modification",
      "category": "maintainability",
      "severity": "high",
      "description": "Modifying global variables inside functions",
      "pattern": "global\\s+\\w+",
      "languages": ["python"],
      "fix": "Pass as parameter and return new value",
      "example": "def update(value): return value + 1",
      "aiGenerated": true
    },
    {
      "id": "AP-022",
      "name": "String Concatenation in Loop",
      "category": "performance",
      "severity": "medium",
      "description": "Inefficient string concatenation in loop",
      "pattern": "for\\s*\\([^)]+\\)\\s*\\{[^}]*\\w+\\s*\\+=\\s*['\"]",
      "languages": ["javascript", "typescript"],
      "fix": "Use array.join() or template literals",
      "example": "const result = items.map(i => i.name).join(',');",
      "aiGenerated": true
    },
    {
      "id": "AP-023",
      "name": "Missing Error Boundary (React)",
      "category": "error-handling",
      "severity": "medium",
      "description": "React component without error boundary",
      "pattern": "class\\s+\\w+\\s+extends\\s+(?:React\\.)?Component(?!.*componentDidCatch)",
      "languages": ["javascript", "typescript"],
      "fix": "Add error boundary or wrap with ErrorBoundary component",
      "example": "componentDidCatch(error, info) { /* handle */ }",
      "aiGenerated": true
    },
    {
      "id": "AP-024",
      "name": "Unoptimized Re-renders (React)",
      "category": "performance",
      "severity": "medium",
      "description": "Component re-renders unnecessarily",
      "pattern": "function\\s+\\w+\\s*\\([^)]*\\)\\s*\\{[^}]*useState[^}]*\\}(?!.*useMemo|useCallback)",
      "languages": ["javascript", "typescript"],
      "fix": "Use React.memo, useMemo, or useCallback",
      "example": "const MemoizedComponent = React.memo(Component);",
      "aiGenerated": true
    },
    {
      "id": "AP-025",
      "name": "Missing Dependency in useEffect",
      "category": "bugs",
      "severity": "high",
      "description": "useEffect missing dependencies",
      "pattern": "useEffect\\s*\\(\\s*\\(\\)\\s*=>\\s*\\{[^}]*\\w+[^}]*\\},\\s*\\[\\s*\\]",
      "languages": ["javascript", "typescript"],
      "fix": "Add all dependencies to dependency array",
      "example": "useEffect(() => { /* use data */ }, [data]);",
      "aiGenerated": true
    }
  ]
}
