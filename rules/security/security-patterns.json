{
  "rules": [
    {
      "id": "SEC-001",
      "name": "Hardcoded API Key",
      "category": "secrets",
      "severity": "critical",
      "description": "Hardcoded API key detected in source code",
      "pattern": "(api[_-]?key|apikey)\\s*[=:]\\s*['\"][a-zA-Z0-9_-]{20,}['\"]",
      "cwe": "CWE-798",
      "owasp": "A02:2021 - Cryptographic Failures",
      "fix": "Store API keys in environment variables or secure key management systems",
      "references": [
        "https://owasp.org/Top10/A02_2021-Cryptographic_Failures/"
      ]
    },
    {
      "id": "SEC-002",
      "name": "Hardcoded Password",
      "category": "secrets",
      "severity": "critical",
      "description": "Hardcoded password detected in source code",
      "pattern": "(password|passwd|pwd)\\s*[=:]\\s*['\"][^'\"]{3,}['\"]",
      "cwe": "CWE-798",
      "owasp": "A02:2021 - Cryptographic Failures",
      "fix": "Never hardcode passwords. Use environment variables or secure vaults",
      "references": [
        "https://owasp.org/Top10/A02_2021-Cryptographic_Failures/"
      ]
    },
    {
      "id": "SEC-003",
      "name": "Hardcoded Secret Token",
      "category": "secrets",
      "severity": "critical",
      "description": "Hardcoded secret token detected",
      "pattern": "(secret|token|auth[_-]?token)\\s*[=:]\\s*['\"][a-zA-Z0-9_-]{20,}['\"]",
      "cwe": "CWE-798",
      "owasp": "A02:2021 - Cryptographic Failures",
      "fix": "Store secrets in environment variables or secret management systems",
      "references": [
        "https://owasp.org/Top10/A02_2021-Cryptographic_Failures/"
      ]
    },
    {
      "id": "SEC-004",
      "name": "SQL Injection Risk",
      "category": "injection",
      "severity": "critical",
      "description": "Potential SQL injection vulnerability detected",
      "pattern": "(execute|query|exec)\\s*\\([^)]*\\+[^)]*\\)",
      "cwe": "CWE-89",
      "owasp": "A03:2021 - Injection",
      "fix": "Use parameterized queries or prepared statements instead of string concatenation",
      "references": [
        "https://owasp.org/Top10/A03_2021-Injection/"
      ]
    },
    {
      "id": "SEC-005",
      "name": "SQL Injection - String Formatting",
      "category": "injection",
      "severity": "critical",
      "description": "SQL query using string formatting (injection risk)",
      "pattern": "(SELECT|INSERT|UPDATE|DELETE).*(%s|\\$\\{|\\+.*\\+)",
      "cwe": "CWE-89",
      "owasp": "A03:2021 - Injection",
      "fix": "Use parameterized queries with placeholders",
      "references": [
        "https://owasp.org/Top10/A03_2021-Injection/"
      ]
    },
    {
      "id": "SEC-006",
      "name": "XSS - innerHTML Usage",
      "category": "xss",
      "severity": "high",
      "description": "Direct innerHTML assignment can lead to XSS",
      "pattern": "\\.innerHTML\\s*=\\s*[^;]+",
      "cwe": "CWE-79",
      "owasp": "A03:2021 - Injection",
      "fix": "Use textContent or sanitize HTML input before assignment",
      "references": [
        "https://owasp.org/Top10/A03_2021-Injection/"
      ]
    },
    {
      "id": "SEC-007",
      "name": "XSS - dangerouslySetInnerHTML",
      "category": "xss",
      "severity": "high",
      "description": "React dangerouslySetInnerHTML can lead to XSS",
      "pattern": "dangerouslySetInnerHTML\\s*=\\s*\\{\\{\\s*__html:",
      "cwe": "CWE-79",
      "owasp": "A03:2021 - Injection",
      "fix": "Sanitize HTML content or use safe React rendering",
      "references": [
        "https://owasp.org/Top10/A03_2021-Injection/"
      ]
    },
    {
      "id": "SEC-008",
      "name": "Unsafe eval() Usage",
      "category": "code-injection",
      "severity": "critical",
      "description": "eval() can execute arbitrary code",
      "pattern": "\\beval\\s*\\(",
      "cwe": "CWE-95",
      "owasp": "A03:2021 - Injection",
      "fix": "Avoid eval(). Use JSON.parse() for JSON or safer alternatives",
      "references": [
        "https://owasp.org/Top10/A03_2021-Injection/"
      ]
    },
    {
      "id": "SEC-009",
      "name": "Unsafe exec() Usage (Python)",
      "category": "code-injection",
      "severity": "critical",
      "description": "exec() can execute arbitrary Python code",
      "pattern": "\\bexec\\s*\\(",
      "cwe": "CWE-95",
      "owasp": "A03:2021 - Injection",
      "fix": "Avoid exec(). Use safer alternatives or validate input strictly",
      "references": [
        "https://owasp.org/Top10/A03_2021-Injection/"
      ]
    },
    {
      "id": "SEC-010",
      "name": "Command Injection Risk",
      "category": "injection",
      "severity": "critical",
      "description": "Potential command injection vulnerability",
      "pattern": "(exec|system|spawn|execSync)\\s*\\([^)]*\\+[^)]*\\)",
      "cwe": "CWE-78",
      "owasp": "A03:2021 - Injection",
      "fix": "Use parameterized commands or validate input strictly",
      "references": [
        "https://owasp.org/Top10/A03_2021-Injection/"
      ]
    },
    {
      "id": "SEC-011",
      "name": "Weak Cryptographic Algorithm - MD5",
      "category": "crypto",
      "severity": "high",
      "description": "MD5 is cryptographically broken",
      "pattern": "\\bmd5\\b",
      "cwe": "CWE-327",
      "owasp": "A02:2021 - Cryptographic Failures",
      "fix": "Use SHA-256 or stronger algorithms",
      "references": [
        "https://owasp.org/Top10/A02_2021-Cryptographic_Failures/"
      ]
    },
    {
      "id": "SEC-012",
      "name": "Weak Cryptographic Algorithm - SHA1",
      "category": "crypto",
      "severity": "high",
      "description": "SHA1 is cryptographically weak",
      "pattern": "\\bsha1\\b",
      "cwe": "CWE-327",
      "owasp": "A02:2021 - Cryptographic Failures",
      "fix": "Use SHA-256 or stronger algorithms",
      "references": [
        "https://owasp.org/Top10/A02_2021-Cryptographic_Failures/"
      ]
    },
    {
      "id": "SEC-013",
      "name": "Insecure Random Number Generation",
      "category": "crypto",
      "severity": "medium",
      "description": "Math.random() is not cryptographically secure",
      "pattern": "Math\\.random\\(\\)",
      "cwe": "CWE-338",
      "owasp": "A02:2021 - Cryptographic Failures",
      "fix": "Use crypto.randomBytes() or crypto.getRandomValues()",
      "references": [
        "https://owasp.org/Top10/A02_2021-Cryptographic_Failures/"
      ]
    },
    {
      "id": "SEC-014",
      "name": "Path Traversal Risk",
      "category": "path-traversal",
      "severity": "high",
      "description": "Potential path traversal vulnerability",
      "pattern": "(readFile|writeFile|open)\\s*\\([^)]*\\.\\.[\\\\/]",
      "cwe": "CWE-22",
      "owasp": "A01:2021 - Broken Access Control",
      "fix": "Validate and sanitize file paths, use path.resolve()",
      "references": [
        "https://owasp.org/Top10/A01_2021-Broken_Access_Control/"
      ]
    },
    {
      "id": "SEC-015",
      "name": "Insecure HTTP Usage",
      "category": "transport",
      "severity": "medium",
      "description": "HTTP used instead of HTTPS",
      "pattern": "http://[^\\s\"']+",
      "cwe": "CWE-319",
      "owasp": "A02:2021 - Cryptographic Failures",
      "fix": "Use HTTPS for all external communications",
      "references": [
        "https://owasp.org/Top10/A02_2021-Cryptographic_Failures/"
      ]
    },
    {
      "id": "SEC-016",
      "name": "Disabled SSL/TLS Verification",
      "category": "transport",
      "severity": "critical",
      "description": "SSL/TLS certificate verification disabled",
      "pattern": "(rejectUnauthorized|verify)\\s*:\\s*false",
      "cwe": "CWE-295",
      "owasp": "A02:2021 - Cryptographic Failures",
      "fix": "Never disable SSL/TLS verification in production",
      "references": [
        "https://owasp.org/Top10/A02_2021-Cryptographic_Failures/"
      ]
    },
    {
      "id": "SEC-017",
      "name": "Unsafe Deserialization",
      "category": "deserialization",
      "severity": "critical",
      "description": "Unsafe deserialization can lead to RCE",
      "pattern": "(pickle\\.loads|yaml\\.load|unserialize)\\s*\\(",
      "cwe": "CWE-502",
      "owasp": "A08:2021 - Software and Data Integrity Failures",
      "fix": "Use safe deserialization methods or validate input",
      "references": [
        "https://owasp.org/Top10/A08_2021-Software_and_Data_Integrity_Failures/"
      ]
    },
    {
      "id": "SEC-018",
      "name": "Debug Mode Enabled",
      "category": "configuration",
      "severity": "medium",
      "description": "Debug mode should not be enabled in production",
      "pattern": "(DEBUG|debug)\\s*[=:]\\s*(True|true|1)",
      "cwe": "CWE-489",
      "owasp": "A05:2021 - Security Misconfiguration",
      "fix": "Disable debug mode in production environments",
      "references": [
        "https://owasp.org/Top10/A05_2021-Security_Misconfiguration/"
      ]
    },
    {
      "id": "SEC-019",
      "name": "Missing Authentication Check",
      "category": "authentication",
      "severity": "high",
      "description": "Route/endpoint without authentication check",
      "pattern": "@(app\\.route|router\\.(get|post|put|delete))\\([^)]+\\)\\s*\\n\\s*def\\s+\\w+",
      "cwe": "CWE-306",
      "owasp": "A07:2021 - Identification and Authentication Failures",
      "fix": "Add authentication middleware or decorators",
      "references": [
        "https://owasp.org/Top10/A07_2021-Identification_and_Authentication_Failures/"
      ]
    },
    {
      "id": "SEC-020",
      "name": "Weak Password Requirements",
      "category": "authentication",
      "severity": "medium",
      "description": "Weak password validation detected",
      "pattern": "password.*length.*<\\s*[1-7]",
      "cwe": "CWE-521",
      "owasp": "A07:2021 - Identification and Authentication Failures",
      "fix": "Enforce strong password requirements (min 8 chars, complexity)",
      "references": [
        "https://owasp.org/Top10/A07_2021-Identification_and_Authentication_Failures/"
      ]
    }
  ]
}
